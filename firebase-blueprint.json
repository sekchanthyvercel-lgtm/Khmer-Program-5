{
  "entities": {
    "AppData": {
      "title": "AppData",
      "description": "The main monolithic app data storage for collaboration.",
      "type": "object",
      "properties": {
        "students": { "type": "array" },
        "settings": { "type": "object" },
        "attendance": { "type": "object" },
        "moduleLocks": { "type": "object" },
        "staffDirectory": { "type": "object" },
        "systemLocked": { "type": "boolean" },
        "updatedAt": { "type": "string" }
      }
    }
  },
  "firestore": {
    "portal/data": {
      "schema": { "$ref": "#/entities/AppData" },
      "description": "Main document storing the entire application state."
    }
  }
}
